{
  "expo": {
    "name": "Hooked",
    "slug": "hooked-app",
    "version": "1.0.0",
    "scheme": "hooked",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "supportsTablet": true,
      "config": {
        "googleMapsApiKey": "AIzaSyAjTFmxkqP-ej7_JJMlSaEyJ9tNsFZfyvg"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.anonymous.hookedapp",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAjTFmxkqP-ej7_JJMlSaEyJ9tNsFZfyvg"
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
